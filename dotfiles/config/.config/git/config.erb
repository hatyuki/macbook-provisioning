[alias]
	tree = log --graph --pretty=oneline --abbrev-commit --decorate
	ch = rev-parse --short --verify HEAD
[color]
	ui = true
[core]
	pager = lv -c
	sparseCheckout = true
	quotepath = false
[credential "https://source.developers.google.com"]
	helper = gcloud.sh
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[ghq]
	root = ~/Sources
[init]
	defaultBranch = main
[merge]
	ff = false
[pull]
	rebase = false
	ff = only

[include]
	path = ~/.config/git/includes/user.<%= @node %>

; vim: ft=gitconfig
